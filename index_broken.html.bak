	<style id="apexus-style-inline-css" type="text/css">
		:root {
			--primary-color: #020261;
			--second-color: #68758c;
			--third-color: #68758c;
			--body-color: #A3A3A3;
			--heading-color: #0f1217;
			--primary-color-rgb: 2, 2, 97;
			--second-color-rgb: 104, 117, 140;
			--third-color-rgb: 104, 117, 140;
			--body-color-rgb: 163, 163, 163;
			--heading-color-rgb: 15, 18, 23;
			--link-color: #0a0a0a;
			--link-color-hover: #f91111;
			--link-color-active: #f91111;
			--body-font-family: 'Outfit', sans-serif;
			--body-font-size: 16px;
			--body-font-weight: normal;
			--body-line-height: 1.5;
			--body-letter-spacing: 0;
			--content-bg-color: #fbfbfc;
			--heading-font-family: 'Outfit', sans-serif;
			--heading-font-weight: 500;
			--heading-text-transform: none;
			--heading-line-height: 1;
			--heading-letter-spacing: -1.92px;
			--heading-color-hover: var(--link-color);
			--heading-font-size-h1: 64px;
			--heading-font-size-h2: 48px;
			--heading-font-size-h3: 40px;
			--heading-font-size-h4: 36px;
			--heading-font-size-h5: 32px;
			--heading-font-size-h6: 24px;
			--logo-width: 140px;
			--logo-mobile_width: 110px;
		}

		.pxl-logo img {
			max-width: 140px !important;
			height: auto !important;
		}

		@media (max-width: 767px) {
			.pxl-logo img {
				max-width: 110px !important;
			}
		}

		/* Red accents */
		.pxl-primary-menu>li:hover>a .pxl-menu-title {
			color: #f91111 !important;
		}

		.pxl-primary-menu>li:hover>a .pxl-menu-title:after {
			background: #f91111 !important;
		}

		.pxl-primary-menu>li.active>a .pxl-menu-title {
			color: #f91111 !important;
		}

		.pxl-primary-menu>li.active>a .pxl-menu-title:after {
			background: #f91111 !important;
		}

		#pxl-footer a:hover {
			color: #f91111 !important;
		}

		[data-id="2740c7e"] {
			background-color: #f91111 !important;
			background-image: none !important;
		}

		/*# sourceURL=apexus-style-inline-css */
	</style>
